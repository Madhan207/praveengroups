# Production Environment Variables for Django Backend on Hostinger (praveengroups.in)
SECRET_KEY=change_this_to_a_random_50_char_secret_key
DEBUG=False
ALLOWED_HOSTS=praveengroups.in,www.praveengroups.in,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://praveengroups.in,https://www.praveengroups.in
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://praveengroups.in,https://www.praveengroups.in

# Database (Optional: Only if using PostgreSQL/MySQL on Hostinger VPS)
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
