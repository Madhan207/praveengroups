# Production Environment Variables for Vite React Frontend on Hostinger
# Set this to your production API endpoint (e.g. https://yourdomain.com/api or https://api.yourdomain.com/api)
VITE_API_URL=/api

# Set this to your production media endpoint (e.g. https://yourdomain.com or https://api.yourdomain.com)
VITE_MEDIA_URL=
